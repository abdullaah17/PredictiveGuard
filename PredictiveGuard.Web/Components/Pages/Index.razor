@page "/"
@using System.ComponentModel.DataAnnotations
@using PredictiveGuard.Web.Services
@using PredictiveGuard.Data.Models
@inject ApiService ApiService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Dashboard - Predictive Guard</PageTitle>

<div class="container mt-5">
    <h1>Asset Dashboard</h1>
    
    <AuthorizeView>
        <Authorized>
            <button class="btn btn-primary mb-3" @onclick="ShowCreateAssetModal">+ New Asset</button>
            
            @if (assets == null)
            {
                <p>Loading assets...</p>
            }
            else if (assets.Count == 0)
            {
                <p>No assets found. Create one to get started.</p>
            }
            else
            {
                <div class="row">
                    @foreach (var asset in assets)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">@asset.Name</h5>
                                    <p class="card-text">
                                        <strong>Type:</strong> @asset.Type<br>
                                        <strong>Location:</strong> @asset.Location<br>
                                        <strong>Status:</strong> @(asset.IsActive ? "Active" : "Inactive")
                                    </p>
                                    <a href="@($"asset/{asset.Id}")" class="btn btn-sm btn-info">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </Authorized>
        <NotAuthorized>
            <p>Please log in to view assets.</p>
        </NotAuthorized>
    </AuthorizeView>
</div>

<!-- Create Asset Modal -->
@if (showCreateModal)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Asset</h5>
                    <button type="button" class="btn-close" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="newAsset" OnSubmit="HandleCreateAsset">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Asset Name</label>
                            <InputText class="form-control" @bind-Value="newAsset.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Type</label>
                            <InputText class="form-control" @bind-Value="newAsset.Type" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <InputText class="form-control" @bind-Value="newAsset.Location" />
                        </div>

                        <button type="submit" class="btn btn-primary">Create</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Asset> assets;
    private bool showCreateModal = false;
    private CreateAssetModel newAsset = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        assets = await ApiService.GetAssetsAsync();
    }

    private void ShowCreateAssetModal()
    {
        newAsset = new();
        showCreateModal = true;
    }

    private async Task HandleCreateAsset()
    {
        try
        {
            await ApiService.CreateAssetAsync(newAsset.Name, newAsset.Location, newAsset.Type);
            showCreateModal = false;
            await LoadAssets();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private class CreateAssetModel
    {
        [Required(ErrorMessage = "Asset name is required")]
        [StringLength(100)]
        public string Name { get; set; }

        [Required(ErrorMessage = "Type is required")]
        public string Type { get; set; }

        [Required(ErrorMessage = "Location is required")]
        public string Location { get; set; }
    }
}
