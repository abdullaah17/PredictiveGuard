@inherits LayoutComponentBase

<div class="layout-wrapper">
    <div class="sidebar-glass">
        <NavMenu />
    </div>

    <main class="main-content">
        <div class="d-flex justify-content-end align-items-center mb-4 glass-panel px-4 py-3">
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));">
                                <i class="bi bi-person-fill text-white fs-5"></i>
                            </div>
                            <div>
                                <div class="fw-medium text-white lh-1">@context.User.Identity?.Name</div>
                                <small class="text-muted">Administrator</small>
                            </div>
                        </div>
                        <a href="/logout" class="btn-glass text-danger" style="border-color: rgba(239, 68, 68, 0.3);">
                            <i class="bi bi-box-arrow-right me-1"></i> Log out
                        </a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="btn-modern">Log in with Google</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article>
            @Body
        </article>
    </main>
</div>

@implements IDisposable
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            NavigationManager.LocationChanged += HandleLocationChanged;
            await InitializeBackgrounds();
        }
    }

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await InitializeBackgrounds();
    }

    private async Task InitializeBackgrounds()
    {
        try 
        {
            await JSRuntime.InvokeVoidAsync("initGenerativeBackground");
            await JSRuntime.InvokeVoidAsync("initAnimatedCounters");
        }
        catch { /* Ignore JS errors during navigation transition */ }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload text-white fw-bold">Reload</a>
    <span class="dismiss">🗙</span>
</div>
