@inject IJSRuntime JSRuntime

<div class="py-4 px-3 mb-4 text-center border-bottom" style="border-color: var(--border-color) !important;">
    <a class="navbar-brand m-0 p-0 text-center" href="" style="text-decoration: none;">
        <i class="bi bi-shield-check fs-2 text-primary mb-2 d-block mx-auto text-gradient"></i>
        <div class="fs-4 text-white">Predictive<span class="fw-light">Guard</span></div>
    </a>
</div>

<div class="nav-scrollable px-3">
    <!-- Using the translated React Tabs component styling for the sidebar -->
    <nav class="custom-tabs-list variant-default w-100" data-orientation="vertical">
        <NavLink class="custom-tab w-100 justify-content-start" href="" Match="NavLinkMatch.All">
            <i class="bi bi-grid-1x2"></i> Overview
        </NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="custom-tab w-100 justify-content-start" href="admin">
                    <i class="bi bi-cpu"></i> Admin Console
                </NavLink>
                <NavLink class="custom-tab w-100 justify-content-start" href="admin/offline-cache">
                    <i class="bi bi-cloud-arrow-down"></i> Offline Cache
                </NavLink>
            </Authorized>
        </AuthorizeView>
        
        <div class="custom-tab-indicator"></div>
    </nav>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initAnimatedTabs");
        }
    }
}
